.page{
  background:#121222
}
.navCon{
  background: #252533;
  color: white;
  border-radius: 40rpx;
}
.naview{
  padding: 20rpx 0;
}
.naviewActive{
  background: #0FB36F;
  border-radius: 40rpx;
}


.container {
  width: 100%;
  height: 100%;
}

.timing {
  width: 90%;
  height: 85%;
  color: #fff;
  padding: 0px 5%;
  overflow: auto;
}

.addTiming {
  width: 100%;
  height: 15%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.timingView {
  margin-top: 30rpx;
  border-top: 1px solid #4D515A;
  padding-top: 30rpx;
}

.timingView:first-child {
  border-top: 0;
  padding-top: 0rpx;
}

.timingViewText {
  display: block
}

.timingViewtime {
  margin-bottom: 20rpx;
}

.timingSonView {
  display: inline-block;
  vertical-align: middle;
}

.timingViewLeft {
  width: 80%;
}

.timingViewRight {
  width: 20%;
  text-align: right
}

.addBtn {
  height: 100rpx;
  border-radius: 30rpx;
  background: #252533;
  color: #0FB36F;
  line-height: 100rpx;
  border:0px;
}