@import "/utils/uicss.wxss";
page {
  background: #131222;
  font-size: 28rpx;
  color: white;
  height: 100%;
}

.bottom_nav{
  position: absolute;
  bottom: 120rpx;
  border-radius: 35rpx;
  height: 70rpx;
  line-height: 70rpx;
  overflow: hidden;
  width: 100%;
  text-align: center;
}
.top_nav{
  position: absolute;
  top: 80rpx;
  border-radius: 35rpx;
  height: 70rpx;
  line-height: 70rpx;
  overflow: hidden;
  width: 70%;
  left: 15%;
  text-align: center;
  background-color: rgba(255, 255, 255, 0.08);
}
.top_nav_item{
  width: 50%;
}
.nav_active{
  background-color: #0FB36F;
  border-radius: 35rpx;
}
.conCon{
  border:1px solid red;
  height: 500rpx;
}
.conCon_shan{
  height: 500rpx;
  border: 1px solid gold;
}
.dian{
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  margin-top: 12rpx;
}

.swiper-item{
  display: block;
  height: 600rpx;
  color: #fff;
  text-align: center;
  font-size: 20px;
  overflow: visible;
  transform: scale(0.9);
  will-change: transform;
  width: 60%;
  margin-left: 20%;
}

.swiper-item-active {
  transform: scale(1);
  will-change: transform;
}

.maiImg{
  display: block;
  margin: 0 auto;
  margin-top: 50rpx;
  width: 360rpx;
  height: 360rpx;
}
.slideres{
  height: 80rpx;
  line-height: 80rpx;
  margin-top: 30rpx;
}
.addslid{
  margin-top: -10rpx;
}
.scene_slider2{
  width: 90%;
  height: 90rpx;
  border-radius: 20rpx;
  overflow: hidden;
  margin-top: 40rpx;
  margin-bottom: 200rpx;
}