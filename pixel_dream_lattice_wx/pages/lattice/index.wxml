<view class="wid-100 row flex-wrap flex-around" style="opacity:{{closeFlag?0.6:1}};">
  <view class="wid-40 menuItem column flex-center btnClick {{toggleDelay?'animation-slide-bottom':''}}" wx:for="{{menuList}}" wx:key="key" wx:if="{{txtRed ? (index==2 || index==4  || index==6 ): true}}"
    bindtap="clickMenu" id="{{index}}" style="animation-delay: {{(index+1)*0.1}}s;">
    <image class="menuItem_bg" mode="aspectFill" src="/img/menu{{index}}.jpg"></image>
    <image class="menuItem_icon" mode="aspectFill" src="/img/icon{{index}}.png"></image>
    <view class="text-xl" style="margin-top:23rpx;">
      {{lang[item.key]}}
    </view>
  </view>
  <view class="btnView wid-40 menuItem   btnClick {{toggleDelay?'animation-slide-bottom':''}}" wx:if="{{!txtRed}}" style="animation-delay: {{(menuList.length)*0.1}}s;">
    <view class="btn right flexCC" catchtap="righting">
      <image class="w100 h100" mode="aspectFill" src="/img/righting.png"/>
    </view>
    <view class="btn rotate flexCC" style="transform: rotate({{rotate}}deg);" catchtap="rotate">
      <image class="w100 h100" mode="aspectFill" src="/img/rotate.png"/>
    </view>
    <view class="btn rotate flexCC" catchtap="jxChange">
      <image class="w100 h100" mode="aspectFill" src="/img/jx{{jxFlag?'ed':''}}.png"/>
    </view>
    <view class="btn right flexCC" bindtap="calibration">
      <image class="w100 h100" mode="aspectFill" src="/img/LineOrder.png"/>
    </view>
  </view>
  <view class="wid-40 menuItem column flex-center btnClick {{toggleDelay?'animation-slide-bottom':''}}"></view>
  <view class="wid-100" style="height:80rpx;" />
  <!-- 颜色校准 -->
  <ledturnhc id="ledturnRef"></ledturnhc>
</view>
